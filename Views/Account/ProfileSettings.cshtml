@model ArabamTR.Controllers.ProfileSettingsViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr" class="h-full bg-slate-950">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Profil Ayarları - ArabamTR</title>
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                },
            },
        }
    </script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>
<body class="h-full flex flex-col justify-between text-slate-200 selection:bg-rose-500 selection:text-white overflow-x-hidden">

    <!-- Decorative background elements -->
    <div class="absolute inset-0 -z-10 overflow-hidden">
        <div class="absolute left-[10%] top-[-20%] h-[800px] w-[800px] rounded-full bg-rose-500/5 blur-[150px]"></div>
        <div class="absolute right-[10%] bottom-[-20%] h-[800px] w-[800px] rounded-full bg-red-600/5 blur-[150px]"></div>
    </div>

    <!-- Header / Navigation -->
    <header class="w-full border-b border-white/10 bg-slate-950/80 backdrop-blur-md sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
            <div class="flex items-center gap-8">
                <a href="/" class="text-2xl font-bold tracking-tight bg-gradient-to-r from-rose-500 to-red-500 bg-clip-text text-transparent hover:opacity-90 transition-opacity">
                    Arabam<span class="text-white">TR</span>
                </a>
                <nav class="hidden md:flex items-center gap-6 text-sm font-medium text-slate-400">
                    <a href="/" class="hover:text-white transition-colors">Ana Sayfa</a>
                    <a href="/Vehicle" class="hover:text-white transition-colors">İlanlar</a>
                    <a href="/Message" class="hover:text-white transition-colors">Mesajlar</a>
                </nav>
            </div>
            <div class="flex items-center gap-4">
                <span class="text-sm text-slate-400 font-medium hidden sm:inline-block">Hoş geldiniz, <span class="text-white font-semibold">@Model.Name</span></span>
                <a asp-controller="Account" asp-action="Logout" class="text-sm font-semibold bg-white/5 hover:bg-white/10 border border-white/10 text-white px-4 py-2 rounded-xl transition-all duration-200">
                    Çıkış Yap
                </a>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow max-w-4xl w-full mx-auto px-6 py-12">
        <div class="space-y-8">
            
            <!-- Welcome Banner / Section Title -->
            <div>
                <h1 class="text-3xl font-extrabold tracking-tight text-white">Hesap Ayarları</h1>
                <p class="text-sm text-slate-400 mt-1">Üyelik bilgilerinizi, dil tercihinizi ve güvenlik ayarlarınızı buradan yönetin.</p>
            </div>

            <!-- Profile Settings Card -->
            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl shadow-2xl p-8">
                
                <form asp-controller="Account" asp-action="ProfileSettings" method="post" class="space-y-8">
                    
                    <!-- Alert Message -->
                    @if (ViewData["SuccessMessage"] != null)
                    {
                        <div class="bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm rounded-xl p-4 flex items-center gap-3">
                            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            <span>@ViewData["SuccessMessage"]</span>
                        </div>
                    }

                    <!-- Validation Summary -->
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="bg-red-500/10 border border-red-500/20 text-red-400 text-sm rounded-xl p-4 space-y-1">
                            <div asp-validation-summary="All" class="font-medium"></div>
                        </div>
                    }

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        
                        <!-- Name Input -->
                        <div>
                            <label asp-for="Name" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2"></label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-500">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                                </div>
                                <input asp-for="Name" class="block w-full pl-10 pr-4 py-3 bg-slate-900/60 border border-white/10 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-rose-500/50 focus:border-rose-500 transition-all duration-200" placeholder="Ad Soyad" required />
                            </div>
                            <span asp-validation-for="Name" class="text-red-400 text-xs mt-1 block"></span>
                        </div>

                        <!-- Email Input -->
                        <div>
                            <label asp-for="Email" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2"></label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-500">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                                </div>
                                <input asp-for="Email" type="email" class="block w-full pl-10 pr-4 py-3 bg-slate-900/60 border border-white/10 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-rose-500/50 focus:border-rose-500 transition-all duration-200" placeholder="E-Posta Adresi" required />
                            </div>
                            <span asp-validation-for="Email" class="text-red-400 text-xs mt-1 block"></span>
                        </div>

                        <!-- Language Dropdown -->
                        <div>
                            <label asp-for="SelectedLanguage" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2"></label>
                            <div class="relative">
                                <select asp-for="SelectedLanguage" class="block w-full appearance-none px-4 py-3 bg-slate-900/60 border border-white/10 rounded-xl text-white focus:outline-none focus:ring-2 focus:ring-rose-500/50 focus:border-rose-500 transition-all duration-200">
                                    <option value="TR" class="bg-slate-950 text-white">Türkçe (TR)</option>
                                    <option value="EN" class="bg-slate-950 text-white">English (EN)</option>
                                    <option value="DE" class="bg-slate-950 text-white">Deutsch (DE)</option>
                                </select>
                                <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none text-slate-400">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                </div>
                            </div>
                            <span asp-validation-for="SelectedLanguage" class="text-red-400 text-xs mt-1 block"></span>
                        </div>

                    </div>

                    <!-- 2FA Section -->
                    <div class="border-t border-white/10 pt-6">
                        <div class="flex items-start justify-between">
                            <div class="space-y-1">
                                <h3 class="text-base font-semibold text-white">İki Adımlı Doğrulama (2FA)</h3>
                                <p class="text-sm text-slate-400 max-w-md">Giriş yaparken hesabınızın güvenliğini artırmak için e-posta yoluyla ek doğrulama kodu gönderilmesini isteyebilirsiniz.</p>
                            </div>
                            
                            <!-- Toggle Button -->
                            <div class="flex items-center">
                                <label class="relative inline-flex items-center cursor-pointer select-none">
                                    <input type="checkbox" asp-for="Is2FAEnabled" class="sr-only peer" />
                                    <div class="w-14 h-7 bg-slate-800 rounded-full peer peer-focus:ring-2 peer-focus:ring-rose-500/30 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-0.5 after:left-[4px] after:bg-slate-400 after:border-slate-400 after:border after:rounded-full after:h-6 after:w-6 after:transition-all peer-checked:bg-rose-500 peer-checked:after:bg-white peer-checked:after:border-white"></div>
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- Save Changes Button -->
                    <div class="flex justify-end pt-4">
                        <button type="submit" class="w-full sm:w-auto py-3 px-8 bg-gradient-to-r from-rose-500 to-red-600 hover:from-rose-600 hover:to-red-700 text-white font-semibold rounded-xl shadow-lg shadow-rose-500/20 hover:shadow-rose-500/30 focus:outline-none focus:ring-2 focus:ring-rose-500/50 active:scale-[0.98] transition-all duration-200">
                            Değişiklikleri Kaydet
                        </button>
                    </div>

                </form>

            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="w-full text-center py-6 text-xs text-slate-500 border-t border-white/5 bg-slate-950/80 backdrop-blur-md">
        &copy; 2026 ArabamTR. Tüm hakları saklıdır.
    </footer>

    <!-- Client-side validation scripts -->
    <script src="https://lib/jquery/dist/jquery.min.js"></script>
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
</body>
</html>
