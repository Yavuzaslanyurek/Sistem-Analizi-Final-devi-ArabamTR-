@inject Microsoft.AspNetCore.Identity.UserManager<ArabamTR.Models.User> UserManager
@{
    Layout = null; // Diğer Layout dosyalarıyla çakışmayı tamamen önler

    var currentUser = User.Identity?.IsAuthenticated == true 
        ? await UserManager.GetUserAsync(User) 
        : null;
    var displayName = currentUser?.Name ?? User.Identity?.Name ?? "";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ArabamTR - Akıllı Kontrol Paneli</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.jsdelivr.net/npm/@@tailwindcss/browser@@4"></script>
    <style>
        /* Mesajlaşma kutusu için özel scroll bar */
        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-track { background: #0f172a; }
        ::-webkit-scrollbar-thumb { background: #334155; border-radius: 10px; }
    </style>
</head>
<body class="bg-gray-950 text-gray-100 font-sans min-h-screen p-4 flex flex-col gap-4">

    <!-- HEADER -->
    <header class="bg-gray-900 border border-gray-800 p-4 sticky top-0 z-50 shadow-md rounded-2xl max-w-7xl w-full mx-auto flex justify-between items-center">
        <h1 class="text-xl font-bold tracking-wider text-indigo-400 flex items-center gap-2">
            🚗 Arabam<span class="text-white bg-indigo-600 px-1.5 py-0.5 rounded text-sm">TR</span>
        </h1>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="flex items-center gap-3">
                <span class="text-xs text-gray-400">Hoş geldiniz, <span class="text-white font-semibold">@displayName</span></span>
                <a asp-controller="Account" asp-action="ProfileSettings" onclick="window.location.href=this.href; return false;" class="text-xs bg-gray-800 hover:bg-gray-700 px-3.5 py-2 rounded-xl border border-gray-700 text-gray-300 font-semibold transition duration-200">⚙️ Profil Ayarları</a>
                <a asp-controller="Account" asp-action="Logout" onclick="window.location.href=this.href; return false;" class="text-xs bg-rose-600/15 hover:bg-rose-600/25 border border-rose-500/20 text-rose-400 px-3.5 py-2 rounded-xl font-semibold transition duration-200">Çıkış Yap</a>
            </div>
        }
        else
        {
            <div class="flex items-center gap-2">
                <a asp-controller="Account" asp-action="Login" onclick="window.location.href=this.href; return false;" class="text-xs bg-gray-800 hover:bg-gray-700 px-3.5 py-2 rounded-xl border border-gray-700 text-gray-300 font-semibold transition duration-200">Giriş Yap</a>
                <a asp-controller="Account" asp-action="Register" onclick="window.location.href=this.href; return false;" class="text-xs bg-indigo-600 hover:bg-indigo-700 px-3.5 py-2 rounded-xl text-white font-semibold shadow-md shadow-indigo-600/10 transition duration-200">Kayıt Ol</a>
            </div>
        }
    </header>

    <!-- ANA PANEL CONTAINER -->
    <div class="flex-1 max-w-7xl w-full mx-auto grid grid-cols-1 lg:grid-cols-4 gap-6 items-start">

        <!-- SOL PANEL: FİLTRE -->
        <aside class="bg-gray-900 p-5 rounded-2xl border border-gray-800 shadow-sm">
            <h3 class="font-bold text-gray-200 mb-4 flex items-center gap-2 text-sm uppercase tracking-wider">🛠️ Donanım Filtresi</h3>
            <div class="space-y-2" id="filter-options">
                <!-- JavaScript dinamik dolduracak -->
            </div>
        </aside>

        <!-- ORTA PANEL: İLANLAR VE DETAY -->
        <main class="lg:col-span-2 space-y-6">
            <h2 class="text-lg font-bold text-gray-300 flex justify-between items-center">
                <span>📋 Güncel Otomobil İlanları</span>
                <span id="ad-count" class="text-xs bg-gray-800 px-2 py-1 rounded border border-gray-700 text-indigo-400">3 İlan</span>
            </h2>

            <!-- İlan Listesi -->
            <div class="grid grid-cols-1 gap-4" id="vehicle-list">
                <!-- JavaScript ilanları basacak -->
            </div>

            <!-- İlan Detay Alanı (Varsayılan olarak gizli, tıklanınca açılır) -->
            <div id="detail-panel" class="bg-gray-900 p-5 rounded-2xl border border-indigo-500/40 shadow-xl hidden">
                <div class="flex justify-between items-start border-b border-gray-800 pb-3">
                    <div>
                        <span class="text-xs font-semibold uppercase tracking-wider text-indigo-400">Seçili İlan Detayları</span>
                        <h3 id="detail-title" class="text-xl font-bold text-white mt-1">Volkswagen Golf</h3>
                    </div>
                    <button onclick="closeDetail()" class="text-gray-500 hover:text-white text-sm bg-gray-800 hover:bg-gray-700 w-7 h-7 rounded-full flex items-center justify-center transition">✕</button>
                </div>

                <!-- Tramer Sorgusu -->
                <div class="mt-4 bg-gray-950 p-4 rounded-xl border border-gray-800">
                    <h4 class="text-xs font-bold text-gray-300 uppercase mb-2">🔍 Ücretsiz Bulut Tramer Sorgusu</h4>
                    <div class="flex gap-2">
                        <input type="text"
                               id="plate-input"
                               placeholder="ÖRN: 34ABC123"
                               class="flex-1 bg-gray-900 border border-gray-700 rounded-lg px-3 py-1.5 text-sm uppercase text-white focus:outline-none focus:border-indigo-500" />
                        <button onclick="queryTramer()" class="bg-indigo-600 hover:bg-indigo-700 px-4 py-1.5 rounded-lg text-xs font-semibold transition">Sorgula</button>
                    </div>
                    <div id="tramer-result" class="mt-3 p-3 rounded-lg border text-xs hidden"></div>
                </div>

                <!-- Fiyat Trend Grafiği -->
                <div class="bg-gray-800 p-4 rounded-xl border border-gray-700 mt-6">
                    <h4 class="text-sm font-semibold text-gray-400 mb-3">📉 Son 12 Aylık Fiyat Trendi</h4>
                    <div class="h-32 flex items-end justify-between gap-2 pt-4 px-2 bg-gray-900 rounded-lg border border-gray-800">
                        <div class="w-full flex flex-col items-center gap-1"><div class="w-full bg-blue-500 rounded-t h-16 animate-all duration-500"></div><span class="text-[10px] text-gray-500">Oca</span></div>
                        <div class="w-full flex flex-col items-center gap-1"><div class="w-full bg-blue-500 rounded-t h-20 animate-all duration-500"></div><span class="text-[10px] text-gray-500">Mar</span></div>
                        <div class="w-full flex flex-col items-center gap-1"><div class="w-full bg-blue-500 rounded-t h-24 animate-all duration-500"></div><span class="text-[10px] text-gray-500">May</span></div>
                        <div class="w-full flex flex-col items-center gap-1"><div class="w-full bg-indigo-500 rounded-t h-28 animate-all duration-500"></div><span class="text-[10px] text-gray-500">Tem</span></div>
                        <div class="w-full flex flex-col items-center gap-1"><div class="w-full bg-indigo-500 rounded-t h-26 animate-all duration-500"></div><span class="text-[10px] text-gray-500">Eyl</span></div>
                        <div class="w-full flex flex-col items-center gap-1"><div class="w-full bg-emerald-500 rounded-t h-32 animate-all duration-500"></div><span class="text-[10px] text-gray-500">Kas</span></div>
                    </div>
                </div>
            </div>
        </main>

        <!-- SAĞ PANEL: SOHBET -->
        <aside class="bg-gray-900 p-4 rounded-2xl border border-gray-800 flex flex-col h-[400px] shadow-sm sticky top-24">
            <div class="border-b border-gray-800 pb-3 mb-3">
                <h3 class="font-bold text-gray-200">💬 İlan İçi Mesajlaşma</h3>
                <div class="text-[11px] text-gray-400 mt-0.5 flex items-center gap-1.5">
                    <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span> Ahmet Yılmaz ile Sohbet
                </div>
            </div>

            <!-- Mesajlaşma Alanı -->
            <div class="flex-1 overflow-y-auto space-y-2 pr-1" id="chat-messages">
                <!-- Mesajlar dinamik eklenecek -->
            </div>

            <!-- Mesaj Gönderme Formu -->
            <div class="mt-3 flex gap-2 border-t border-gray-800 pt-3">
                <input type="text"
                       id="chat-input"
                       placeholder="Mesajınızı yazın..."
                       class="flex-1 bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-xs text-white focus:outline-none focus:border-indigo-500"
                       onkeypress="if(event.key === 'Enter') sendChatMessage()" />
                <button onclick="sendChatMessage()" class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 rounded-xl text-xs font-semibold transition">Gönder</button>
            </div>
        </aside>

    </div>

    <!-- JAVASCRIPT MOTORU -->
    <script>
        // Veri Setleri
        const availableFeatures = [
            { id: 1, name: 'Sunroof' },
            { id: 2, name: 'Koltuk Isıtma' },
            { id: 3, name: 'Şerit Takip' },
            { id: 4, name: 'Elektrikli Bagaj' },
            { id: 5, name: 'Hayalet Gösterge' }
        ];

        const initialVehicles = [
            { id: 101, title: 'Volkswagen Golf 1.5 eTSI Style', price: '1.450.000 TL', km: '45.000', year: 2024, plate: '34ABC123', aiBadge: 'Normal Fiyat', aiColor: 'bg-blue-500/15 text-blue-400 border border-blue-500/20', features: [1, 2, 5] },
            { id: 102, title: 'BMW 320i Sedan M Sport', price: '2.850.000 TL', km: '12.000', year: 2025, plate: '06XYZ999', aiBadge: 'Fiyatı Çok İyi', aiColor: 'bg-emerald-500/15 text-emerald-400 border border-emerald-500/20', features: [1, 2, 3, 4, 5] },
            { id: 103, title: 'Toyota Corolla 1.8 Hybrid Dream', price: '1.180.000 TL', km: '85.000', year: 2023, plate: '34YVZ555', aiBadge: 'Yüksek Fiyat', aiColor: 'bg-rose-500/15 text-rose-400 border border-rose-500/20', features: [3] }
        ];

        let selectedFeatures = [];
        let selectedVehicle = null;
        let chatMessages = [
            { sender: 'Ahmet Yılmaz', text: 'Araçta boya var mı?' },
            { sender: 'Sen', text: 'Sadece sağ çamurluk lokal boyalı.' }
        ];

        // Sistemi Başlat
        window.onload = function() {
            renderFilters();
            renderVehicles();
            renderChat();
        };

        // Filtreleri Çiz
        function renderFilters() {
            const container = document.getElementById('filter-options');
            container.innerHTML = availableFeatures.map(f => `
                <label class="flex items-center gap-3 p-2 rounded-lg hover:bg-gray-800/60 cursor-pointer transition">
                    <input
                        type="checkbox"
                        value="${f.id}"
                        onchange="toggleFeature(${f.id})"
                        class="rounded bg-gray-950 border-gray-700 text-indigo-600 focus:ring-indigo-500 w-4 h-4"
                    />
                    <span class="text-sm text-gray-300">${f.name}</span>
                </label>
            `).join('');
        }

        // Filtre Durumunu Değiştir
        function toggleFeature(id) {
            if (selectedFeatures.includes(id)) {
                selectedFeatures = selectedFeatures.filter(x => x !== id);
            } else {
                selectedFeatures.push(id);
            }
            renderVehicles();
        }

        // Araçları Listele
        function renderVehicles() {
            const container = document.getElementById('vehicle-list');

            const filtered = initialVehicles.filter(v =>
                selectedFeatures.length === 0 ? true : selectedFeatures.every(fId => v.features.includes(fId))
            );

            document.getElementById('ad-count').innerText = `${filtered.length} İlan Listeleniyor`;

            if(filtered.length === 0) {
                container.innerHTML = `<p class="text-gray-500 text-sm italic p-4 text-center">Aradığınız donanımlara uygun araç bulunamadı.</p>`;
                return;
            }

            container.innerHTML = filtered.map(v => {
                const isSelected = selectedVehicle?.id === v.id;
                return `
                    <div
                        onclick="selectVehicle(${v.id})"
                        class="p-4 bg-gray-900 rounded-2xl border transition cursor-pointer flex flex-col justify-between h-44 hover:scale-[1.01] ${isSelected ? 'border-indigo-500 shadow-lg shadow-indigo-500/10' : 'border-gray-800 hover:border-gray-700'}"
                    >
                        <div>
                            <div class="flex justify-between items-start">
                                <h3 class="font-semibold text-white text-base">${v.title}</h3>
                                <span class="text-[11px] font-medium px-2 py-0.5 rounded-full ${v.aiColor}">🤖 ${v.aiBadge}</span>
                            </div>
                            <p class="text-xs text-gray-400 mt-1">Yıl: ${v.year} — KM: ${v.km}</p>
                        </div>
                        <div class="text-right border-t border-gray-800/60 pt-2 flex justify-between items-center">
                            <span class="text-xs text-gray-500">Plaka: ${v.plate}</span>
                            <span class="text-lg font-bold text-indigo-400">${v.price}</span>
                        </div>
                    </div>
                `;
            }).join('');
        }

        // Araç Seçimi
        function selectVehicle(id) {
            selectedVehicle = initialVehicles.find(v => v.id === id);

            // Detay panelini doldur ve aç
            document.getElementById('detail-title').innerText = selectedVehicle.title;
            document.getElementById('detail-panel').classList.remove('hidden');
            document.getElementById('tramer-result').classList.add('hidden');
            document.getElementById('plate-input').value = selectedVehicle.plate;

            renderVehicles(); // Seçili kartın border rengini güncellemek için yeniden çiziyoruz
        }

        function closeDetail() {
            document.getElementById('detail-panel').classList.add('hidden');
            selectedVehicle = null;
            renderVehicles();
        }

        // Tramer Sorgulama Motoru
        function queryTramer() {
            const val = document.getElementById('plate-input').value.trim().toUpperCase();
            const resDiv = document.getElementById('tramer-result');
            resDiv.classList.remove('hidden');

            if (val === '34ABC123') {
                resDiv.className = "mt-3 p-3 rounded-lg border text-xs bg-emerald-950/40 border-emerald-800 text-emerald-300";
                resDiv.innerHTML = `<strong>📋 Sorgu Sonucu: Temiz, Hasarsız Raporu</strong><br>Hasar Tutar: 0 TL | KM: 45.000 KM`;
            } else if (val === '06XYZ999') {
                resDiv.className = "mt-3 p-3 rounded-lg border text-xs bg-rose-950/40 border-rose-800 text-rose-300";
                resDiv.innerHTML = `<strong>📋 Sorgu Sonucu: Ağır Hasar Kayıtlı</strong><br>Hasar Tutar: 145.000 TL | KM: 12.000 KM`;
            } else {
                resDiv.className = "mt-3 p-3 rounded-lg border text-xs bg-emerald-950/40 border-emerald-800 text-emerald-300";
                resDiv.innerHTML = `<strong>📋 Sorgu Sonucu: Sistemde Hasar Kaydı Bulunmuyor</strong><br>Hasar Tutar: 0 TL | KM: Güncel`;
            }
        }

        // Sohbet Paneli Motoru
        function renderChat() {
            const container = document.getElementById('chat-messages');
            container.innerHTML = chatMessages.map(m => {
                const isMe = m.sender === 'Sen';
                return `
                    <div class="flex flex-col max-w-[85%] ${isMe ? 'ml-auto items-end' : 'mr-auto items-start'}">
                        <div class="p-2.5 rounded-2xl text-xs ${isMe ? 'bg-indigo-600 text-white rounded-tr-none' : 'bg-gray-800 text-gray-200 rounded-tl-none'}">
                            ${m.text}
                        </div>
                    </div>
                `;
            }).join('');
            container.scrollTop = container.scrollHeight;
        }

        function sendChatMessage() {
            const input = document.getElementById('chat-input');
            const txt = input.value.trim();
            if(!txt) return;

            chatMessages.push({ sender: 'Sen', text: txt });
            input.value = '';
            renderChat();
        }
    </script>
</body>
</html>
